<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.common.module.business.material.category.CategoryCommonDao">

    <!-- 根据父级id 查询子类 -->
    <select id="queryByParentId"
            resultType="net.lab1024.tms.common.module.business.material.category.domain.CategoryEntity">
        SELECT * FROM t_category
        WHERE parent_id IN
        <foreach collection="parentIdList" open="(" separator="," close=")" item="id">#{id}</foreach>
        AND deleted_flag = #{deletedFlag}
        ORDER BY sort ASC, category_id ASC
    </select>

    <!-- 查看类目 -->
    <select id="selectOne" resultType="net.lab1024.tms.common.module.business.material.category.domain.CategoryEntity">
        SELECT * FROM t_category
        <where>
            <if test="categoryType != null">
                AND category_type = #{categoryType}
            </if>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            <if test="categoryName != null">
                AND category_name = #{categoryName}
            </if>
            <if test="deletedFlag != null">
                AND deleted_flag = #{deletedFlag}
            </if>
        </where>
        LIMIT 1
    </select>

    <select id="selectByTypeAndId"
            resultType="net.lab1024.tms.common.module.business.material.category.domain.CategoryEntity">
        select * from  t_category where category_type = #{categoryType} and category_id = #{categoryId}
    </select>

    <select id="selectByType"
            resultType="net.lab1024.tms.common.module.business.material.category.domain.CategoryEntity">
        select * from  t_category where category_type = #{categoryType}
    </select>


    <select id="selectByTypeDeletedFlag"
            resultType="net.lab1024.tms.common.module.business.material.category.domain.CategoryEntity">
        select * from t_category where category_type = #{categoryType}  AND deleted_flag = #{deletedFlag}
        ORDER BY sort ASC, category_id ASC
    </select>

    <select id="queryByParentIdAndType"
            resultType="net.lab1024.tms.common.module.business.material.category.domain.CategoryEntity">
        SELECT * FROM t_category
        WHERE parent_id IN
        <foreach collection="parentIdList" open="(" separator="," close=")" item="id">#{id}</foreach>
        AND category_type = #{categoryType}
        AND deleted_flag = #{deletedFlag}
        ORDER BY sort ASC , category_id ASC
    </select>
</mapper>