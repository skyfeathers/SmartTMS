<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.common.module.business.mobileapp.MobileAppDao">

    <select id="selectByNewestFlag"
            resultType="net.lab1024.tms.common.module.business.mobileapp.domain.entity.MobileAppEntity">
        SELECT *
        FROM t_mobile_app
        WHERE platform_type = #{platformType} AND newest_flag = #{newestFlag}
    </select>

    <select id="queryPage" resultType="net.lab1024.tms.common.module.business.mobileapp.domain.vo.MobileAppVO">
        SELECT *
        FROM t_mobile_app
        <where>
            <if test="queryForm.platformType != null">
                AND platform_type = #{queryForm.platformType}
            </if>
            <if test="queryForm.keywords != null and queryForm.keywords != ''">
                AND INSTR(version_no, #{queryForm.keywords})
            </if>
        </where>
        <if test="queryForm.sortItemList == null or queryForm.sortItemList.size == 0">
            ORDER BY id DESC
        </if>
    </select>

    <update id="updateNewestFlag">
        UPDATE t_mobile_app
        SET newest_flag = #{newestFlag}
        WHERE id = #{id}
    </update>

</mapper>