<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.common.module.support.dingding.sync.dao.DingDingDepartmentDao">


    <select id="getByDepartmentId"
            resultType="net.lab1024.tms.common.module.support.dingding.sync.domain.DingDingDepartmentEntity">
        SELECT
        *
        FROM
        t_ding_ding_department
        where department_id = #{departmentId}
    </select>

    <select id="getByDeptId"
            resultType="net.lab1024.tms.common.module.support.dingding.sync.domain.DingDingDepartmentEntity">
        SELECT
        *
        FROM
            t_ding_ding_department
        where dept_id = #{deptId}
    </select>

    <select id="selectByEnterpriseId"
            resultType="net.lab1024.tms.common.module.support.dingding.sync.domain.DingDingDepartmentEntity">
        select * from t_ding_ding_department where enterprise_id = #{enterpriseId}
    </select>
</mapper>