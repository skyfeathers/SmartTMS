<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.common.module.support.dingding.sync.dao.DingDingEmployeeDao">


    <select id="selectByEnterpriseUserId"
            resultType="net.lab1024.tms.common.module.support.dingding.sync.domain.DingDingEmployeeEntity">
        select * from t_ding_ding_employee where enterprise_id = #{enterpriseId} and user_id = #{userId}
    </select>
    <select id="selectByUserIdList"
            resultType="net.lab1024.tms.common.module.support.dingding.sync.domain.DingDingEmployeeEntity">
        select * from t_ding_ding_employee where user_id in
        <foreach collection="userIdList" item="item" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>
</mapper>