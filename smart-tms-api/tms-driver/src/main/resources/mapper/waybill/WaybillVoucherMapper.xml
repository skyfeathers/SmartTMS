<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.driver.module.business.waybill.dao.WaybillVoucherDao">

    <select id="selectByWaybillId"
            resultType="net.lab1024.tms.common.module.business.waybill.domain.vo.WaybillVoucherVO">
        SELECT *
        FROM t_waybill_voucher
        WHERE waybill_id = #{waybillId}
    </select>

    <select id="selectByWaybillIdAndType"
            resultType="net.lab1024.tms.common.module.business.waybill.domain.entity.WaybillVoucherEntity">
        SELECT *
        FROM t_waybill_voucher
        WHERE waybill_id = #{waybillId} AND type = #{type}
    </select>

</mapper>