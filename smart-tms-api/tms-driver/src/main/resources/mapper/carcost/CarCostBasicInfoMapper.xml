<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.driver.module.business.carcost.basicinfo.CarCostBasicInfoDao">

    <select id="selectConfirmFlagByWaybillId" resultType="java.lang.Boolean">
