<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.driver.module.business.driver.dao.DriverBankDao">

    <sql id="selectByDriverId">
        SELECT *
        FROM t_driver_bank
        WHERE driver_id = #{driverId}
    </sql>

    <select id="selectByDriverId"
            resultType="net.lab1024.tms.common.module.business.driver.domain.DriverBankEntity">
        <include refid="selectByDriverId" />
    </select>

    <select id="selectDefaultBankByDriverId"
            resultType="net.lab1024.tms.common.module.business.driver.domain.DriverBankEntity">
        <include refid="selectByDriverId" />
        AND default_flag = #{defaultFlag}
    </select>
</mapper>