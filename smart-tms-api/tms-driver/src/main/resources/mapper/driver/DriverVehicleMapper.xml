<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.driver.module.business.vehicle.dao.DriverVehicleDao">

    <select id="selectByDriverAndVehicle"
            resultType="net.lab1024.tms.common.module.business.drivervehicle.DriverVehicleEntity">
        SELECT * FROM t_driver_vehicle where driver_id = #{driverId} and vehicle_id = #{vehicleId}
    </select>

</mapper>