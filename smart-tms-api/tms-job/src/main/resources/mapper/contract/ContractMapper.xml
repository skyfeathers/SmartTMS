<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.job.module.contract.ContractDao">

    <select id="selectByExpireDate" resultType="net.lab1024.tms.common.module.business.contract.domain.ContractEntity">
        SELECT * FROM t_contract where  DATE_FORMAT(expiration_date, '%Y-%m-%d') =DATE_FORMAT( now(), '%Y-%m-%d')
    </select>
</mapper>