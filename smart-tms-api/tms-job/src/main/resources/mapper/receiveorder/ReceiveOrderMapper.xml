<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.job.module.receiveorder.ReceiveOrderDao">

    <select id="selectByShipperIdList" resultType="net.lab1024.tms.job.module.receiveorder.domain.ShipperSimpleDTO">
        select * from t_shipper where shipper_id in
        <foreach collection="shipperIdList" open="(" close=")" item="item" separator=",">
            #{item}
        </foreach>
    </select>

    <select id="selectByAccountPeriodDate"
            resultType="net.lab1024.tms.common.module.business.receive.domain.ReceiveOrderEntity">
        select * from t_receive_order where  DATE_FORMAT(account_period_date, '%Y-%m-%d') =DATE_FORMAT( now(), '%Y-%m-%d')
        AND verification_flag = #{verificationFlag}
    </select>
</mapper>