<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.receive.dao.ReceiveOrderMailAddressDao">

    <select id="selectByReceiveOrderIdList"
            resultType="net.lab1024.tms.common.module.business.receive.domain.ReceiveOrderMailAddressEntity">
        SELECT * FROM t_receive_order_mail_address where receive_order_id in
        <foreach collection="receiveOrderIdList" item="item" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>
</mapper>