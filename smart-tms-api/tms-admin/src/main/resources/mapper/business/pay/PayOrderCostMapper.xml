<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.pay.dao.PayOrderCostDao">


    <select id="selectByPayOrderId"
            resultType="net.lab1024.tms.common.module.business.pay.domain.PayOrderCostEntity">
        select * from t_pay_order_cost where pay_order_id = #{payOrderId}
    </select>

    <select id="selectByPayOrderIdList"
            resultType="net.lab1024.tms.common.module.business.pay.domain.PayOrderCostEntity">
        select * from t_pay_order_cost where pay_order_id in
        <foreach collection="payOrderIdList" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
    </select>



</mapper>