<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.material.cost.CostItemDao">

    <update id="updateDeleteFlag">
        update
        t_cost_item
        set deleted_flag = #{deletedFlag}
        where
        cost_item_id = #{costItemId}
    </update>


    <select id="queryPage" resultType="net.lab1024.tms.admin.module.business.material.cost.domain.CostItemVO">
        SELECT *
        FROM t_cost_item
        <where>
            <if test="queryForm.keywords != null and queryForm.keywords != ''">
                AND INSTR(`name`,#{queryForm.keywords})
            </if>
            <if test="queryForm.type != null">
                AND `type` = #{queryForm.type}
            </if>
            <if test="queryForm.category != null">
                AND category = #{queryForm.category}
            </if>
            <if test="queryForm.deletedFlag != null">
                AND deleted_flag = #{queryForm.deletedFlag}
            </if>
        </where>
        <if test="queryForm.sortItemList == null or queryForm.sortItemList.size == 0">
            ORDER BY `type`,seq
        </if>
    </select>

    <select id="selectByType"
            resultType="net.lab1024.tms.common.module.business.material.cost.domain.CostItemEntity">
        select * from t_cost_item where deleted_flag = #{deletedFlag} and `type` in
        <foreach collection="typeList" open="(" close=")" separator="," item="item">
            #{item}
        </foreach>
    </select>

</mapper>