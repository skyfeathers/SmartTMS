<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.driver.dao.DriverBankDao">

    <update id="updateDeletedFlag">
        update t_driver_bank set deleted_flag = #{deletedFlag} where driver_id  in
        <foreach collection="driverIdList" separator="," open="(" close=")" item="item">
            #{item}
        </foreach>
    </update>

    <select id="selectByDriverId" resultType="net.lab1024.tms.common.module.business.driver.domain.DriverBankEntity">
        select * from t_driver_bank where driver_id = #{driverId} order by default_flag desc
    </select>

    <select id="selectDefaultByDriverId"
            resultType="net.lab1024.tms.common.module.business.driver.domain.DriverBankEntity">
        select * from t_driver_bank where driver_id = #{driverId} and default_flag = #{defaultFlag} limit 1
    </select>

    <delete id="deleteByDriverIdExcludeIds">
        DELETE FROM t_driver_bank
        WHERE driver_id = #{driverId}
        <if test="excludeIds != null and excludeIds.size > 0">
            AND bank_id NOT IN
            <foreach collection="excludeIds" open="(" close=")" separator="," item="id">
                #{id}
            </foreach>
        </if>
    </delete>

</mapper>