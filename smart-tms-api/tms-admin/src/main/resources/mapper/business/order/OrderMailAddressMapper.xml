<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.order.dao.OrderMailAddressDao">

    <select id="selectByOrderId" resultType="net.lab1024.tms.common.module.business.order.domain.OrderMailAddressEntity">
        SELECT * FROM t_order_mail_address where order_id = #{orderId}
    </select>

    <delete id="deleteByOrderId">
        DELETE FROM t_order_mail_address where order_id = #{orderId}
    </delete>
</mapper>