<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.order.dao.OrderPathDao">

    <select id="selectByOrderIdList"
            resultType="net.lab1024.tms.common.module.business.order.domain.OrderPathEntity">
        SELECT * FROM t_order_path WHERE order_id in
        <foreach collection="orderIdList" separator="," open="(" close=")" item="item">
            #{item}
        </foreach>
    </select>


    <delete id="deleteByOrderId">
        DELETE FROM t_order_path WHERE order_id = #{orderId}
    </delete>
</mapper>