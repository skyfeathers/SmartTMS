<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.fleet.dao.FleetBankDao">

    <update id="updateDeletedFlagByFleetId">
        update t_fleet_bank set deleted_flag = #{deletedFlag} where fleet_id in
        <foreach collection="fleetIdList" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
    </update>

    <delete id="deleteByFleetId">
        delete from  t_fleet_bank where fleet_id = #{fleetId}
    </delete>

    <select id="selectByFleetId" resultType="net.lab1024.tms.common.module.business.fleet.domain.FleetBankEntity">
        select * from t_fleet_bank where fleet_id = #{fleetId} order by default_flag desc
    </select>
    <select id="selectDefaultByFleetId"
            resultType="net.lab1024.tms.common.module.business.fleet.domain.FleetBankEntity">
        select * from t_fleet_bank where fleet_id = #{fleetId} and default_flag = #{defaultFlag} limit 1
    </select>
</mapper>