<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.material.transportroute.TransportRoutePathDao">

    <select id="selectByTransportRouteIdList"
            resultType="net.lab1024.tms.admin.module.business.material.transportroute.domain.dto.TransportRoutePathDTO">
        SELECT * FROM t_transport_route_path where transport_route_id in
        <foreach collection="list" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
    </select>


    <delete id="deleteByTransportRouteId">
        delete from t_transport_route_path where transport_route_id = #{transportRouteId}
    </delete>
</mapper>