<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.admin.module.business.material.contracttype.ContractTypeDao">

    <update id="updateDeleteFlag">
        update
            t_contract_type
        set deleted_flag = #{deletedFlag}
        where
            contract_type_id = #{contractTypeId}
    </update>

    <select id="selectByNameAndExcludeIds"
            resultType="net.lab1024.tms.common.module.business.material.contracttype.ContractTypeEntity">
        select * from t_contract_type where `name` = #{name} and deleted_flag = #{deletedFlag}
        <if test="excludeIds != null and excludeIds.size > 0">
            and contract_type_id not in
            <foreach collection="excludeIds" open="(" close=")" separator="," item="item">
                #{item}
            </foreach>
        </if>
    </select>

    <select id="queryPage" resultType="net.lab1024.tms.admin.module.business.material.contracttype.domain.ContractTypeVO">
        SELECT *
        FROM t_contract_type
        <where>
            <if test="queryForm.keywords != null and queryForm.keywords != ''">
                AND INSTR(`name`,#{queryForm.keywords})
            </if>
            <if test="queryForm.deletedFlag != null">
                AND deleted_flag = #{queryForm.deletedFlag}
            </if>
        </where>
        <if test="queryForm.sortItemList == null or queryForm.sortItemList.size == 0">
            ORDER BY seq ASC, contract_type_id DESC
        </if>
    </select>
    <select id="queryAll"
            resultType="net.lab1024.tms.admin.module.business.material.contracttype.domain.ContractListVO">
        SELECT
            contract_type_id, name
        FROM t_contract_type
        where deleted_flag = #{deletedFlag}
        ORDER BY seq ASC, contract_type_id DESC
    </select>

</mapper>