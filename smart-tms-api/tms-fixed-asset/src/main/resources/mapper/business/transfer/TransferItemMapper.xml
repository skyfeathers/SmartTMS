<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.fixedasset.module.business.transfer.dao.TransferItemDao">

    <select id="queryByTransferIdList" resultType="net.lab1024.tms.fixedasset.module.business.transfer.domain.TransferItemEntity">
        SELECT * FROM t_asset_transfer_item
        where transfer_id IN
        <foreach collection="transferIdList" open="(" close=")" separator="," item="item">
            #{item}
        </foreach>
    </select>
</mapper>