<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.fixedasset.module.business.consumables.check.dao.ConsumablesCheckEmployeeDao">

    <select id="queryByCheckIdList" resultType="net.lab1024.tms.fixedasset.module.business.consumables.check.domain.entity.ConsumablesCheckEmployeeEntity">
        SELECT * FROM t_consumables_check_employee
        where check_id IN
        <foreach collection="checkIdList" open="(" close=")" separator="," item="item">
            #{item}
        </foreach>
    </select>

    <select id="queryByCheckId" resultType="java.lang.Long">
        SELECT employee_id FROM t_consumables_check_employee
        where check_id = #{checkId}
    </select>
</mapper>