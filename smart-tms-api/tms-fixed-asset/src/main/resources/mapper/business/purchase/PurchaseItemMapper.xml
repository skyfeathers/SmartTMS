<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.tms.fixedasset.module.business.purchase.dao.PurchaseItemDao">

    <select id="queryByPurchaseIdList" resultType="net.lab1024.tms.fixedasset.module.business.purchase.domain.PurchaseItemEntity">
        SELECT * FROM t_asset_purchase_item
        where purchase_id IN
        <foreach collection="purchaseIdList" open="(" close=")" separator="," item="item">
            #{item}
        </foreach>
    </select>
</mapper>